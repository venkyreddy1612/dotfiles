[global]
    monitor = 0
    follow = mouse

    width = 300
    height = 200
    origin = top-right
    offset = 20x60

    scale = 0

    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8

    transparency = 10

    corner_radius = 12

    frame_width = 2
    frame_color = "#3584e4"

    separator_height = 2
    padding = 12
    horizontal_padding = 12

    font = JetBrainsMono Nerd Font 10

    line_height = 3

    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left

    show_age_threshold = 60

    word_wrap = true

    idle_threshold = 120

    history_length = 20

    browser = xdg-open

    always_run_script = true

    title = Dunst

    class = Dunst

[urgency_low]
    timeout = 5
    background = "#1e1e1e"
    foreground = "#ffffff"

[urgency_normal]
    timeout = 8
    background = "#1e1e1e"
    foreground = "#ffffff"

[urgency_critical]
    timeout = 0
    background = "#1e1e1e"
    foreground = "#ff6c6b"
    frame_color = "#ff6c6b"
